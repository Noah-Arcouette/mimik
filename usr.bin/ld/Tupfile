include_rules

# toolchain build
ifeq (@(BUILD_TOOL_LD),y)
: foreach *.c |> !hostcc |> $(OBJ)/tool/ld.d/%B.o {tool-obj}
: {tool-obj} |> !hostccld |> $(OBJ)/tool/ld | $(OBJ)/tool/<ld>
endif


ifeq (@(USR_BIN_LD),y)
: foreach *.c |> !cc |> $(OBJ)/usr.bin/ld/%B.o {obj}
: {obj} |> !ccld |> $(DIST)/usr/bin/ld
endif
