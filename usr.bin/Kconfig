menu "usr.bin/ - non-essential user binaries"
	config USR_BIN_UNAME
		bool "uname"
		help
			Print system identification information

	config USR_BIN_TTY
		bool "tty"
		help
			Get user's terminal name

	config USR_BIN_HEAD
		bool "head"
		help
			Copy the first parts of a file

	config USR_BIN_LOGNAME
		bool "logname"
		help
			Print the user's login name

	config USR_BIN_ECHO
		bool "echo"
		help
			Print strings
endmenu
