include_rules

ifeq (@(USR_BIN_COMPRESS),y)

ifeq (@(USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZW),y)
FLAGS=-DDEFAULT_LZW
endif
ifeq (@(USR_LIB_LIBZIO_DEFAULT_COMPRESS_DEFLATE),y)
FLAGS=-DDEFAULT_DEFLATE
endif
ifeq (@(USR_LIB_LIBZIO_DEFAULT_COMPRESS_GZIP),y)
FLAGS=-DDEFAULT_GZIP
endif

: compress.c | $(OBJ)/usr.lib/<libzio> |> !ccld $(FLAGS) -lzio \
	|> $(DIST)/usr/bin/%B
endif

COPIES=

ifeq (@(USR_BIN_UNCOMPRESS),y)
COPIES+=uncompress
endif

ifeq (@(USR_BIN_ZCAT),y)
COPIES+=zcat
endif

ifeq (@(USR_BIN_GZIP),y)
COPIES+=gzip
endif

ifeq (@(USR_BIN_GUNZIP),y)
COPIES+=gunzip
endif

: foreach $(COPIES) |> !cp |> $(DIST)/usr/bin/%b

# toolchain build
ifeq (@(BUILD_COMPRESS),y)
ifeq (@(BUILD_COMPRESS_WITH_LZW),y)
FLAGS=-DDEFAULT_LZW
endif
ifeq (@(BUILD_COMPRESS_WITH_DEFLATE),y)
FLAGS=-DDEFAULT_DEFLATE
endif
ifeq (@(BUILD_COMPRESS_WITH_GZIP),y)
FLAGS=-DDEFAULT_GZIP
endif

: compress.c | $(OBJ)/tool/<libzio> |> !hostccld $(FLAGS) $(OBJ)/tool/libzio.a \
	|> $(OBJ)/tool/%B | $(OBJ)/tool/<compress>
endif
