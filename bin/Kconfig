menu "bin/ - essential user binaries"
	config BIN_CAT
		bool "cat"
		help
			Concatenate files together

	config BIN_ECHO
		bool "echo"
		help
			Print strings

	config BIN_UNAME
		bool "uname"
		help
			Print system identification information

	config BIN_TTY
		bool "tty"
		help
			Get user's terminal name

	config BIN_HEAD
		bool "head"
		help
			Copy the first parts of a file

	config BIN_LOGNAME
		bool "logname"
		help
			Print the user's login name

	config BIN_TRUE
		bool "true"
		help
			Return true

	config BIN_FALSE
		bool "false"
		help
			Return false

	config BIN_TEE
		bool "tee"
		help
			Save the contents of standard input

	config BIN_READLINK
		bool "readlink"
		help
			Show where a symbolic link leads to

	config BIN_SLEEP
		bool "sleep"
		help
			Pause execution
endmenu
