.gitignore

# Output files
ROOT=$(TUP_CWD)
OBJ=$(ROOT)/@(BUILD_OBJ)/
DIST=$(ROOT)/@(BUILD_DIST)/

# Host Toolchain
!hostccld = |> ^ HOSTCCLD %b^ @(BUILD_CC) @(BUILD_CFLAGS)    -o %o %f |>
!hostcc   = |> ^ HOSTCC   %b^ @(BUILD_CC) @(BUILD_CFLAGS) -c -o %o %f |>

EXEC=@(BUILD_EXEC)

# Built Toolchain
ifeq (@(BUILD_HOST),y)
!ccld = !hostccld
!cc = !hostcc
endif

# For compressible text file specifically
!txtcp = |> ^ TXTCP    %b^ cp %f %o |>
