	# config USR_LIB_LIBZIO_DES

	# config USR_LIB_LIBZIO_UUENCODE

	comment "Defaults"
	choice USR_LIB_LIBZIO_DEFAULT_COMPRESS
		bool "Default compression method"

		config USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZW
			bool "lzw"
			select USR_LIB_LIBZIO_LZW
			help
				This is not very efficient nor is it common place anymore
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_PACK

		config USR_LIB_LIBZIO_DEFAULT_COMPRESS_DEFLATE
			bool "deflate"
			select USR_LIB_LIBZIO_DEFLATE
			help
				This is a streaming compression algorithm and is not recommended
				as the default, use zlib at least please
		config USR_LIB_LIBZIO_DEFAULT_COMPRESS_GZIP
			bool "gzip"
			select USR_LIB_LIBZIO_GZIP
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_ZLIB

		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZMA
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZMA2
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_XZ
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZIP

		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_ZSTD
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_BROTLI

		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_BZIP
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_BZIP2
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_BZIP3
		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_RZIP

		# config USR_LIB_LIBZIO_DEFAULT_COMPRESS_LZ4
