menuconfig USR_LIB_LIBZIO
	bool "libzio"
	help
		Alternative encoding library
if USR_LIB_LIBZIO
	comment "Outputs"
	config USR_LIB_LIBZIO_SO
		bool "libzio.so"
	config USR_LIB_LIBZIO_A
		bool "libzio.a"

	comment "Formats"
	config USR_LIB_LIBZIO_LZW
		bool "lzw"
		help
			LZW, this is the legacy unix compress utility
	# config USR_LIB_LIBZIO_PACK

	config USR_LIB_LIBZIO_DEFLATE
		bool "deflate"
		help
			This is one of the most common stream compression methods.
			Usually wrapped in gzip or zip
	config USR_LIB_LIBZIO_GZIP
		bool "gzip"
		help
			The ubiquitous compressor for most unix-like systems
		select USR_LIB_LIBZIO_DEFLATE
	# config USR_LIB_LIBZIO_ZLIB
	# config USR_LIB_LIBZIO_ZIP

	# config USR_LIB_LIBZIO_LZMA
	# config USR_LIB_LIBZIO_LZMA2
	# config USR_LIB_LIBZIO_XZ
	# config USR_LIB_LIBZIO_LZIP
